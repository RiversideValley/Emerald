<ContentDialog
    x:Class="Emerald.Views.AddGameDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Emerald.Helpers.Converters"
    xmlns:corexIns="using:Emerald.CoreX.Installers"
    xmlns:corexVer="using:Emerald.CoreX.Versions"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:Emerald.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:Emerald.ViewModels"
    Margin="12"
    Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}"
    x:Name="Root"
    mc:Ignorable="d">

  <ContentDialog.Resources>

    <x:Double x:Key="ContentDialogMaxWidth">2000</x:Double>
    <x:Double x:Key="ContentDialogMaxHeight">2000</x:Double>
    <conv:BoolToVisibility x:Key="BoolToVis" />
    <conv:BoolToVisibility x:Key="InverseBoolToVis" Reversed="True" />
    <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    <conv:StepToVisibilityConverter x:Key="StepToVisibilityConverter" />
    <conv:CountToVisibilityConverter x:Key="CountToVis" />

    <DataTemplate x:Key="VersionTemplate" x:DataType="corexVer:Version">
      <Border
        Margin="0,0,0,8"
        Padding="14"
        CornerRadius="12"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1">
        <Grid ColumnSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind BasedOn}" />
            <TextBlock
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="{x:Bind ReleaseType}" />
          </StackPanel>

          <Border
            Grid.Column="1"
            Padding="10,4"
            VerticalAlignment="Center"
            Background="{ThemeResource SystemAccentColorLight3}"
            CornerRadius="12">
            <TextBlock
              Foreground="{ThemeResource SystemAccentColorDark1}"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="{x:Bind ReleaseType}" />
          </Border>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="ModLoaderTypeTemplate" x:DataType="viewModels:AddGameModLoaderTypeOption">
      <StackPanel MaxWidth="140" Margin="0,0,12,0" Spacing="4">
        <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind Title}" TextWrapping="WrapWholeWords" />
        <TextBlock
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          Style="{StaticResource CaptionTextBlockStyle}"
          Text="{x:Bind Description}"
          TextWrapping="WrapWholeWords" />
      </StackPanel>
    </DataTemplate>

    <DataTemplate x:Key="LoaderTemplate" x:DataType="corexIns:LoaderInfo">
      <Border
        Margin="0,0,0,8"
        Padding="14"
        CornerRadius="12"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1">
        <StackPanel Spacing="4">
          <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind Version}" />
          <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{helpers:Localize KeyName=ModLoaderVersionDescription}" />
        </StackPanel>
      </Border>
    </DataTemplate>
  </ContentDialog.Resources>

  <Grid HorizontalAlignment="Stretch">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border
      Grid.Row="0"
      Padding="20,20,20,14">
      <StackPanel Spacing="16">
        <StackPanel Spacing="6">
          <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{helpers:Localize KeyName=AddNewGame}" />
          <TextBlock
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{helpers:Localize KeyName=AddNewGameDescription}"
            TextWrapping="WrapWholeWords" />
        </StackPanel>

      </StackPanel>
    </Border>

    <Grid Grid.Row="1" HorizontalAlignment="Stretch" Padding="20,16,20,16">
      <Grid
        HorizontalAlignment="Stretch"
        Visibility="{x:Bind ViewModel.AddGameWizardStep, Mode=OneWay, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=0}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <AutoSuggestBox
          Grid.Row="0"
          PlaceholderText="{helpers:Localize KeyName=SearchMinecraftVersionsPlaceholder}"
          QueryIcon="Find"
          Text="{x:Bind ViewModel.VersionSearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <RadioButtons
          Grid.Row="1"
          HorizontalAlignment="Stretch"
          Margin="0,16,0,12"
          ItemsSource="{x:Bind ViewModel.ReleaseTypes, Mode=OneWay}"
          MaxColumns="4"
          SelectedItem="{x:Bind ViewModel.SelectedReleaseTypeFilter, Mode=TwoWay}">
          <RadioButtons.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding}" />
            </DataTemplate>
          </RadioButtons.ItemTemplate>
        </RadioButtons>

        <Grid Grid.Row="2">
          <ListView
            ItemTemplate="{StaticResource VersionTemplate}"
            ItemsSource="{x:Bind ViewModel.FilteredAvailableVersions, Mode=OneWay}"
            SelectedItem="{x:Bind ViewModel.SelectedVersion, Mode=TwoWay}"
            SelectionMode="Single" />

          <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{x:Bind ViewModel.FilteredAvailableVersions.Count, Mode=OneWay, Converter={StaticResource CountToVis}, ConverterParameter=0}">
            <FontIcon FontSize="40" Glyph="&#xE8B8;" Opacity="0.5" />
            <TextBlock
              HorizontalAlignment="Center"
              Style="{StaticResource SubtitleTextBlockStyle}"
              Text="{helpers:Localize KeyName=NoMinecraftVersionsFound}" />
            <TextBlock
              HorizontalAlignment="Center"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="{helpers:Localize KeyName=NoMinecraftVersionsFoundDescription}"
              TextWrapping="WrapWholeWords" />
          </StackPanel>
        </Grid>
      </Grid>

      <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        Visibility="{x:Bind ViewModel.AddGameWizardStep, Mode=OneWay, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=1}">
        <StackPanel Spacing="20">
          <Border
            Padding="14"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <StackPanel Spacing="4">
              <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind ViewModel.AddGameSelectedVersionSummary, Mode=OneWay}" />
              <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.AddGameSelectedVersionReleaseType, Mode=OneWay}" />
            </StackPanel>
          </Border>

          <StackPanel Spacing="12">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{helpers:Localize KeyName=ModLoaderSectionTitle}" />
            <RadioButtons
              ItemsSource="{x:Bind ViewModel.ModLoaderTypes, Mode=OneWay}"
              MaxColumns="3"
              SelectedItem="{x:Bind ViewModel.SelectedModLoaderTypeOption, Mode=TwoWay}"
              ItemTemplate="{StaticResource ModLoaderTypeTemplate}" />

            <StackPanel
              Spacing="12"
              Visibility="{x:Bind ViewModel.IsModLoaderSelectionVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
              <ProgressRing
                Width="28"
                Height="28"
                HorizontalAlignment="Left"
                IsActive="{x:Bind ViewModel.IsLoadingModLoaders, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoadingModLoaders, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

              <ListView
                ItemTemplate="{StaticResource LoaderTemplate}"
                ItemsSource="{x:Bind ViewModel.AvailableModLoaders, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedModLoader, Mode=TwoWay}"
                SelectionMode="Single"
                Visibility="{x:Bind ViewModel.HasAvailableModLoaders, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

              <Border
                Padding="14"
                CornerRadius="12"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Visibility="{x:Bind ViewModel.HasNoAvailableModLoaders, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <StackPanel Spacing="6">
                  <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{helpers:Localize KeyName=NoModLoaderVersionsAvailableTitle}" />
                  <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{helpers:Localize KeyName=NoModLoaderVersionsAvailableDescription}"
                    TextWrapping="WrapWholeWords" />
                </StackPanel>
              </Border>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <ScrollViewer
        VerticalScrollBarVisibility="Auto"
        Visibility="{x:Bind ViewModel.AddGameWizardStep, Mode=OneWay, Converter={StaticResource StepToVisibilityConverter}, ConverterParameter=2}">
        <StackPanel Spacing="20">
          <Border
            Padding="14"
            CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
            <StackPanel Spacing="4">
              <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}" Text="{x:Bind ViewModel.AddGameSelectedVersionSummary, Mode=OneWay}" />
              <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.AddGameSelectedVersionReleaseType, Mode=OneWay}" />
            </StackPanel>
          </Border>

          <StackPanel Spacing="12">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{helpers:Localize KeyName=GameIdentitySectionTitle}" />
            <TextBox
              Header="{helpers:Localize KeyName=InstanceName}"
              PlaceholderText="{helpers:Localize KeyName=InstanceNamePlaceholder}"
              Text="{x:Bind ViewModel.NewGameName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="{helpers:Localize KeyName=InstanceNameDescription}"
              TextWrapping="WrapWholeWords" />
          </StackPanel>

          <StackPanel Spacing="12">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{helpers:Localize KeyName=GameFolderSectionTitle}" />
            <ToggleSwitch
              Header="{helpers:Localize KeyName=CustomizeGameFolderName}"
              IsOn="{x:Bind ViewModel.IsCustomFolderNameEnabled, Mode=TwoWay}"
              OffContent="{helpers:Localize KeyName=UseGameNameDefault}"
              OnContent="{helpers:Localize KeyName=OverrideFolderName}" />
            <TextBox
              Header="{helpers:Localize KeyName=GameFolderName}"
              IsEnabled="{x:Bind ViewModel.IsFolderNameReadOnly, Mode=OneWay, Converter={StaticResource InverseBoolConverter}}"
              PlaceholderText="{helpers:Localize KeyName=GameFolderNamePlaceholder}"
              Text="{x:Bind ViewModel.NewGameFolderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="{helpers:Localize KeyName=GameFolderNameDescription}"
              TextWrapping="WrapWholeWords" />

            <Border
              Padding="12"
              CornerRadius="10"
              Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              Visibility="{x:Bind ViewModel.HasFolderValidationMessage, Mode=OneWay, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="{x:Bind ViewModel.GameFolderValidationMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            </Border>

            <Border
              Padding="12"
              CornerRadius="10"
              Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="1"
              Visibility="{x:Bind ViewModel.HasFolderConflictWarning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
              <TextBlock Text="{x:Bind ViewModel.GameFolderConflictWarningMessage, Mode=OneWay}" TextWrapping="WrapWholeWords" />
            </Border>

            <TextBlock
              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="{x:Bind ViewModel.CurrentGameFolderPathPreview, Mode=OneWay}"
              TextWrapping="WrapWholeWords"
              Visibility="{x:Bind ViewModel.HasCurrentGameFolderPathPreview, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Grid>

    <Border
      Grid.Row="2"
      Padding="20,14,20,20">
      <Grid ColumnSpacing="12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button
          Grid.Column="0"
          Click="Cancel_Click"
          Content="{helpers:Localize KeyName=Cancel}" />

        <Button
          Grid.Column="1"
          Command="{x:Bind ViewModel.GoToPreviousStepCommand}"
          Content="{helpers:Localize KeyName=Back}"
          Visibility="{x:Bind ViewModel.CanGoToPreviousAddGameStep, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

        <Button
          Grid.Column="2"
          Command="{x:Bind ViewModel.GoToNextStepCommand}"
          Content="{helpers:Localize KeyName=Next}"
          IsEnabled="{x:Bind ViewModel.CanGoToNextAddGameStep, Mode=OneWay}"
          Style="{ThemeResource AccentButtonStyle}"
          Visibility="{x:Bind ViewModel.IsOnGameConfigurationStep, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}" />

        <Button
          Grid.Column="2"
          Click="Create_Click"
          Content="{helpers:Localize KeyName=Create}"
          IsEnabled="{x:Bind ViewModel.CanCreateGame, Mode=OneWay}"
          Style="{ThemeResource AccentButtonStyle}"
          Visibility="{x:Bind ViewModel.IsOnGameConfigurationStep, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
      </Grid>
    </Border>
  </Grid>
</ContentDialog>
