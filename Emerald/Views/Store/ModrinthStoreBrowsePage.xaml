<Page
    x:Class="Emerald.Views.Store.ModrinthStoreBrowsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:cn="using:CommunityToolkit.WinUI.Controls"
    xmlns:conv="using:Emerald.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:corex="using:Emerald.CoreX"
    xmlns:helpers="using:Emerald.Helpers"
    xmlns:modrinth="using:Emerald.CoreX.Store.Modrinth.JSON"
    xmlns:viewModels="using:Emerald.ViewModels"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

  <Page.Resources>
    <conv:BoolToVisibility x:Key="BoolToVis" />
    <conv:BoolToVisibility x:Key="InverseBoolToVis" Reversed="True" />
  </Page.Resources>

  <Grid Margin="24,0,24,24" ColumnSpacing="16">
    <Grid.ColumnDefinitions>
      <ColumnDefinition MinWidth="320" MaxWidth="400" />
      <ColumnDefinition />
    </Grid.ColumnDefinitions>

    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <cn:SettingsCard
          Header="Search"
          Description="Search updates live as you type or change filters."
          HeaderIcon="{helpers:FontIcon Glyph=&#xE721;}">
          <StackPanel Spacing="8">
            <TextBox
              PlaceholderText="Search Modrinth projects..."
              Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <TextBlock
              Opacity="0.72"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="Results refresh automatically." />
          </StackPanel>
        </cn:SettingsCard>

        <cn:SettingsExpander
          Header="Context"
          IsExpanded="True"
          Description="Choose the game and content type before you browse."
          HeaderIcon="{helpers:FontIcon Glyph=&#xE81E;}">
          <cn:SettingsExpander.Items>
            <cn:SettingsCard Header="Game">
              <ComboBox
                ItemsSource="{Binding Games}"
                SelectedItem="{Binding SelectedGame, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="corex:Game">
                    <TextBlock Text="{x:Bind Version.DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </cn:SettingsCard>

            <cn:SettingsCard Header="Content type">
              <ComboBox
                DisplayMemberPath="DisplayName"
                ItemsSource="{Binding ContentTypes}"
                SelectedItem="{Binding SelectedContentTypeOption, Mode=TwoWay}" />
            </cn:SettingsCard>

            <cn:SettingsCard Header="Sort by">
              <ComboBox
                DisplayMemberPath="DisplayName"
                ItemsSource="{Binding SortOptions}"
                SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" />
            </cn:SettingsCard>
          </cn:SettingsExpander.Items>
        </cn:SettingsExpander>

        <cn:SettingsExpander
          Header="Categories"
          Description="Category filters apply as soon as you toggle them."
          HeaderIcon="{helpers:FontIcon Glyph=&#xE8EC;}">
          <cn:SettingsExpander.Items>
            <cn:SettingsCard Header="Available filters">
              <ScrollViewer MaxHeight="420" VerticalScrollBarVisibility="Auto">
                <ItemsRepeater ItemsSource="{Binding CategoryFilters}">
                  <ItemsRepeater.Layout>
                    <StackLayout Spacing="8" />
                  </ItemsRepeater.Layout>
                  <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="viewModels:CategoryFilterOption">
                      <ToggleButton
                        Content="{x:Bind DisplayName}"
                        IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                        HorizontalAlignment="Stretch" />
                    </DataTemplate>
                  </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
              </ScrollViewer>
            </cn:SettingsCard>
          </cn:SettingsExpander.Items>
        </cn:SettingsExpander>
      </StackPanel>
    </ScrollViewer>

    <cn:GridSplitter
      Grid.Column="1"
      Width="16"
      HorizontalAlignment="Left"
      ResizeBehavior="BasedOnAlignment"
      ResizeDirection="Auto" />

    <Grid Grid.Column="1" Padding="16,0,0,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <StackPanel Margin="16,0,0,12" Spacing="4">
        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Discover Projects" />
        <TextBlock
          Opacity="0.75"
          Style="{StaticResource CaptionTextBlockStyle}"
          Text="{Binding ResultsStatusText}" />
      </StackPanel>

      <Grid Grid.Row="1">
        <ListView
          ItemsSource="{Binding SearchResults}"
          SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}"
          SelectionMode="Single"
          Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVis}}">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="modrinth:SearchHit">
              <Border
                Margin="0,0,0,12"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="14">
                <Grid ColumnSpacing="16">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Border
                    Width="80"
                    Height="80"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    CornerRadius="12">
                    <Image Source="{x:Bind IconUrl}" Stretch="UniformToFill" />
                  </Border>

                  <StackPanel Grid.Column="1" Spacing="8">
                    <StackPanel Spacing="2">
                      <TextBlock
                        Style="{StaticResource SubtitleTextBlockStyle}"
                        Text="{x:Bind Title}" />
                      <TextBlock
                        Opacity="0.72"
                        Style="{StaticResource CaptionTextBlockStyle}">
                        <Run Text="by " />
                        <Run Text="{x:Bind Author}" />
                      </TextBlock>
                    </StackPanel>

                    <TextBlock
                      MaxLines="2"
                      Opacity="0.82"
                      Style="{StaticResource CaptionTextBlockStyle}"
                      Text="{x:Bind Description}"
                      TextWrapping="WrapWholeWords" />

                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border
                        Padding="8,3"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="999">
                        <TextBlock
                          Opacity="0.85"
                          Style="{StaticResource CaptionTextBlockStyle}"
                          Text="{x:Bind CompatibilityText}" />
                      </Border>

                      <ItemsRepeater ItemsSource="{x:Bind DisplayCategories}">
                        <ItemsRepeater.Layout>
                          <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                          <DataTemplate x:DataType="x:String">
                            <Border
                              Padding="8,3"
                              Background="{ThemeResource LayerFillColorDefaultBrush}"
                              CornerRadius="999">
                              <TextBlock
                                Opacity="0.8"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind}" />
                            </Border>
                          </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                      </ItemsRepeater>
                    </StackPanel>
                  </StackPanel>

                  <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="10">
                    <StackPanel HorizontalAlignment="Right">
                      <TextBlock
                        HorizontalAlignment="Right"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind DownloadCountText}" />
                      <TextBlock
                        HorizontalAlignment="Right"
                        Opacity="0.7"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Downloads" />
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right">
                      <TextBlock
                        HorizontalAlignment="Right"
                        Style="{StaticResource BodyStrongTextBlockStyle}"
                        Text="{x:Bind FollowCountText}" />
                      <TextBlock
                        HorizontalAlignment="Right"
                        Opacity="0.7"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="Followers" />
                    </StackPanel>

                    <TextBlock
                      HorizontalAlignment="Right"
                      Opacity="0.7"
                      Style="{StaticResource CaptionTextBlockStyle}"
                      Text="{x:Bind UpdatedRelativeText}" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <StackPanel
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Spacing="12"
          Visibility="{Binding HasSearchResults, Converter={StaticResource InverseBoolToVis}}">
          <ProgressRing
            IsActive="{Binding IsSearching}"
            Visibility="{Binding IsSearching, Converter={StaticResource BoolToVis}}" />
          <FontIcon
            FontSize="40"
            Glyph="&#xE721;"
            Opacity="0.45"
            Visibility="{Binding IsSearching, Converter={StaticResource InverseBoolToVis}}" />
          <TextBlock
            HorizontalAlignment="Center"
            Style="{StaticResource SubtitleTextBlockStyle}"
            Text="Browse Modrinth" />
          <TextBlock
            MaxWidth="360"
            Opacity="0.75"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="{Binding ResultsStatusText}"
            TextAlignment="Center"
            TextWrapping="WrapWholeWords" />
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Page>
