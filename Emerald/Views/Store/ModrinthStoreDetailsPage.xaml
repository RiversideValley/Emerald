<Page
    x:Class="Emerald.Views.Store.ModrinthStoreDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:Emerald.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:modrinth="using:Emerald.CoreX.Store.Modrinth.JSON"
    xmlns:store="using:Emerald.CoreX.Store"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

  <Page.Resources>
    <conv:BoolToVisibility x:Key="BoolToVis" />
    <conv:BoolToVisibility x:Key="InverseBoolToVis" Reversed="True" />
    <conv:StringToVisibilityConverter x:Key="StringToVis" />
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="24,0,24,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Border
        Padding="16"
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="14">
        <Grid ColumnSpacing="16">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <StackPanel Spacing="8">
            <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Install Target" />
            <TextBlock
              Style="{StaticResource BodyStrongTextBlockStyle}"
              Text="{Binding SelectedGameInstallTargetName}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border
                Padding="8,3"
                Background="{ThemeResource SystemAccentColorLight3Brush}"
                CornerRadius="999">
                <TextBlock
                  Style="{StaticResource CaptionTextBlockStyle}"
                  Text="{Binding SelectedGameLoaderDisplayName}" />
              </Border>
              <Border
                Padding="8,3"
                Background="{ThemeResource SystemAccentColorLight3Brush}"
                CornerRadius="999">
                <TextBlock
                  Style="{StaticResource CaptionTextBlockStyle}"
                  Text="{Binding SelectedGameBaseVersion}" />
              </Border>
            </StackPanel>
          </StackPanel>

          <Button
            Grid.Column="1"
            Command="{Binding InstallSelectedVersionCommand}"
            Content="Install Selected Version"
            IsEnabled="{Binding CanInstall}"
            Style="{ThemeResource AccentButtonStyle}"
            VerticalAlignment="Center" />
        </Grid>
      </Border>

      <Border
        Grid.Row="1"
        Padding="20"
        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="16"
        Margin="0,16,0,0">
        <Grid ColumnSpacing="20">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <Border
            Width="104"
            Height="104"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            CornerRadius="16">
            <Image Source="{Binding SelectedItem.IconUrl}" Stretch="UniformToFill" />
          </Border>

          <StackPanel Grid.Column="1" Spacing="8">
            <StackPanel Spacing="2">
              <TextBlock
                Style="{StaticResource TitleTextBlockStyle}"
                Text="{Binding SelectedItem.Title}" />
              <TextBlock
                Opacity="0.72"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding SelectedSearchResult.Author}" />
            </StackPanel>

            <TextBlock
              MaxLines="4"
              Opacity="0.82"
              Style="{StaticResource BodyTextBlockStyle}"
              Text="{Binding SelectedItem.Description}"
              TextWrapping="WrapWholeWords" />

            <StackPanel Orientation="Horizontal" Spacing="8">
              <Border
                Padding="8,3"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                CornerRadius="999">
                <TextBlock
                  Opacity="0.85"
                  Style="{StaticResource CaptionTextBlockStyle}"
                  Text="{Binding SelectedItem.CompatibilityText}" />
              </Border>

              <ItemsRepeater ItemsSource="{Binding SelectedItem.DisplayCategories}">
                <ItemsRepeater.Layout>
                  <StackLayout Orientation="Horizontal" Spacing="8" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                  <DataTemplate x:DataType="x:String">
                    <Border
                      Margin="0,12,0,0"
                      Padding="8,3"
                      Background="{ThemeResource LayerFillColorDefaultBrush}"
                      CornerRadius="999">
                      <TextBlock
                        Opacity="0.8"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind}" />
                    </Border>
                  </DataTemplate>
                </ItemsRepeater.ItemTemplate>
              </ItemsRepeater>
            </StackPanel>
          </StackPanel>

          <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="10">
            <StackPanel HorizontalAlignment="Right">
              <TextBlock
                HorizontalAlignment="Right"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{Binding SelectedItem.DownloadCountText}" />
              <TextBlock
                HorizontalAlignment="Right"
                Opacity="0.7"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Downloads" />
            </StackPanel>
            <StackPanel HorizontalAlignment="Right">
              <TextBlock
                HorizontalAlignment="Right"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{Binding SelectedItem.FollowCountText}" />
              <TextBlock
                HorizontalAlignment="Right"
                Opacity="0.7"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="Followers" />
            </StackPanel>
            <TextBlock
              HorizontalAlignment="Right"
              Opacity="0.7"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="{Binding SelectedItem.UpdatedRelativeText}" />
          </StackPanel>
        </Grid>
      </Border>

      <Border
        Grid.Row="2"
        Margin="0,12,0,0"
        Padding="12"
        Background="{ThemeResource LayerFillColorDefaultBrush}"
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1"
        CornerRadius="12"
        Visibility="{Binding HasCompatibilityNotice, Converter={StaticResource BoolToVis}}">
        <TextBlock
          Style="{StaticResource CaptionTextBlockStyle}"
          Text="{Binding CompatibilityNotice}"
          TextWrapping="WrapWholeWords" />
      </Border>

      <Grid Grid.Row="3" Margin="0,16,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="4">
          <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="Compatible Versions" />
          <TextBlock
            Opacity="0.75"
            Style="{StaticResource CaptionTextBlockStyle}"
            Text="Choose the version you want before installing it into the selected game." />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,12,0,0">
          <ListView
            ItemsSource="{Binding CompatibleVersions}"
            SelectedItem="{Binding SelectedVersion, Mode=TwoWay}"
            SelectionMode="Single"
            Visibility="{Binding HasCompatibleVersions, Converter={StaticResource BoolToVis}}">
            <ListView.ItemTemplate>
              <DataTemplate x:DataType="modrinth:ItemVersion">
                <Border
                  Margin="0,0,0,12"
                  Padding="16"
                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="14">
                  <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                      </Grid.ColumnDefinitions>

                      <StackPanel Spacing="4">
                        <TextBlock
                          Style="{StaticResource BodyStrongTextBlockStyle}"
                          Text="{x:Bind Name}" />
                        <TextBlock
                          Opacity="0.76"
                          Style="{StaticResource CaptionTextBlockStyle}">
                          <Run Text="{x:Bind VersionNumber}" />
                          <Run Text="  •  " />
                          <Run Text="{x:Bind VersionTypeDisplay}" />
                        </TextBlock>
                      </StackPanel>

                      <StackPanel Grid.Column="1" HorizontalAlignment="Right" Spacing="6">
                        <TextBlock
                          HorizontalAlignment="Right"
                          Style="{StaticResource BodyStrongTextBlockStyle}"
                          Text="{x:Bind DownloadCountText}" />
                        <TextBlock
                          HorizontalAlignment="Right"
                          Opacity="0.7"
                          Style="{StaticResource CaptionTextBlockStyle}"
                          Text="{x:Bind PublishedRelativeText}" />
                      </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Spacing="8">
                      <Border
                        Padding="8,3"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="999">
                        <TextBlock
                          Opacity="0.8"
                          Style="{StaticResource CaptionTextBlockStyle}"
                          Text="{x:Bind PrimaryFileSizeText}" />
                      </Border>

                      <ItemsRepeater ItemsSource="{x:Bind LoaderChips}">
                        <ItemsRepeater.Layout>
                          <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                          <DataTemplate x:DataType="store:StoreTagChip">
                            <Grid>
                              <Border
                                Padding="8,3"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="999"
                                Visibility="{x:Bind IsMatch, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock
                                  Opacity="0.8"
                                  Style="{StaticResource CaptionTextBlockStyle}"
                                  Text="{x:Bind Text}" />
                              </Border>
                              <Border
                                Padding="8,3"
                                Background="{ThemeResource SystemAccentColorLight3Brush}"
                                CornerRadius="999"
                                Visibility="{x:Bind IsMatch, Converter={StaticResource BoolToVis}}">
                                <TextBlock
                                  Style="{StaticResource CaptionTextBlockStyle}"
                                  Text="{x:Bind Text}" />
                              </Border>
                            </Grid>
                          </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                      </ItemsRepeater>

                      <ItemsRepeater ItemsSource="{x:Bind GameVersionChips}">
                        <ItemsRepeater.Layout>
                          <StackLayout Orientation="Horizontal" Spacing="8" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                          <DataTemplate x:DataType="store:StoreTagChip">
                            <Grid>
                              <Border
                                Padding="8,3"
                                Background="{ThemeResource LayerFillColorDefaultBrush}"
                                CornerRadius="999"
                                Visibility="{x:Bind IsMatch, Converter={StaticResource InverseBoolToVis}}">
                                <TextBlock
                                  Opacity="0.8"
                                  Style="{StaticResource CaptionTextBlockStyle}"
                                  Text="{x:Bind Text}" />
                              </Border>
                              <Border
                                Padding="8,3"
                                Background="{ThemeResource SystemAccentColorLight3Brush}"
                                CornerRadius="999"
                                Visibility="{x:Bind IsMatch, Converter={StaticResource BoolToVis}}">
                                <TextBlock
                                  Style="{StaticResource CaptionTextBlockStyle}"
                                  Text="{x:Bind Text}" />
                              </Border>
                            </Grid>
                          </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                      </ItemsRepeater>
                    </StackPanel>

                    <TextBlock
                      Opacity="0.74"
                      Style="{StaticResource CaptionTextBlockStyle}"
                      Text="{x:Bind FileName}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <StackPanel
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{Binding HasCompatibleVersions, Converter={StaticResource InverseBoolToVis}}">
            <ProgressRing
              IsActive="{Binding IsLoadingDetails}"
              Visibility="{Binding IsLoadingDetails, Converter={StaticResource BoolToVis}}" />
            <FontIcon
              FontSize="36"
              Glyph="&#xE8FD;"
              Opacity="0.45"
              Visibility="{Binding IsLoadingDetails, Converter={StaticResource InverseBoolToVis}}" />
            <TextBlock
              HorizontalAlignment="Center"
              Style="{StaticResource SubtitleTextBlockStyle}"
              Text="Select a project first" />
            <TextBlock
              MaxWidth="340"
              Opacity="0.75"
              Style="{StaticResource CaptionTextBlockStyle}"
              Text="Open Discover, pick a project card, and the version list will appear here."
              TextAlignment="Center"
              TextWrapping="WrapWholeWords"
              Visibility="{Binding IsLoadingDetails, Converter={StaticResource InverseBoolToVis}}" />
          </StackPanel>
        </Grid>
      </Grid>

    </Grid>
  </ScrollViewer>
</Page>
